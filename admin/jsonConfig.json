{
  "type": "panel",
  "items": {
    "mainHeader": {
      "type": "header",
      "text": "go2rtc Host"
    },
    "autoStart": {
      "type": "checkbox",
      "label": "Go2rtc beim Adapter-Start automatisch starten"
    },
    "binaryPath": {
      "type": "text",
      "label": "Pfad zur go2rtc Binary"
    },
    "configPath": {
      "type": "text",
      "label": "Pfad zur go2rtc.yaml"
    },
    "workingDir": {
      "type": "text",
      "label": "Arbeitsverzeichnis"
    },
    "autoGenerateConfig": {
      "type": "checkbox",
      "label": "go2rtc.yaml automatisch aus Streams erzeugen"
    },
    "apiListen": {
      "type": "text",
      "label": "API Listen (z. B. :1984)"
    },
    "webrtcListen": {
      "type": "text",
      "label": "WebRTC Listen (z. B. :8555)"
    },
    "rtspListen": {
      "type": "text",
      "label": "RTSP Listen (z. B. :8554 oder 'off')"
    },
    "streamsJson": {
      "type": "text",
      "label": "Streams (JSON)",
      "placeholder": "{\"instar9820\":[\"rtsp://user:pass@ip:554/livestream/11\"]}",
      "help": "Beispiel: {\"instar9820\": [\"rtsp://user:pass@ip:554/livestream/11\"]}"
    },
    "autoDownload": {
      "type": "checkbox",
      "label": "Binary automatisch herunterladen, falls nicht vorhanden"
    },
    "downloadUrl": {
      "type": "text",
      "label": "Download-URL fuer go2rtc Binary"
    }
  }
}
